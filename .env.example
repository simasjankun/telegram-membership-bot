# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Public URL of this app.
# Local dev:    your ngrok URL, e.g. https://abc123.ngrok-free.app
# Production:   your DigitalOcean droplet URL or domain
APP_URL=https://abc123.ngrok-free.app

# ─────────────────────────────────────────
# Database — Supabase
# Get both strings from: Supabase → Project Settings → Database → Connection string
# ─────────────────────────────────────────

# Direct connection (used for migrations)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Pooler connection (used at runtime — handles connection limits)
DATABASE_POOL_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────
# Redis (BullMQ job queues)
# Local dev: run Redis via Docker: docker run -d -p 6379:6379 redis:alpine
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# Jobs
# CRON_SCHEDULE: '* * * * *' every minute (testing), '0 * * * *' every hour (production)
# GRACE_PERIOD_DAYS: days before removal after payment failure (use 0.001 for ~1.5min testing)
# ─────────────────────────────────────────
CRON_SCHEDULE=0 * * * *
GRACE_PERIOD_DAYS=2

# ─────────────────────────────────────────
# Community
# ─────────────────────────────────────────
COMMUNITY_NAME=Inner Light
STANDARD_PACKAGE_NAME=Inner Light
VIP_PACKAGE_NAME=Inner Light Plus

# ─────────────────────────────────────────
# Telegram
# BOT_TOKEN:    BotFather → your bot → API Token
# CHAT IDs:     add @getidsbot to group/channel, it will reply with the ID, then remove it
#               IDs are negative numbers, e.g. -1001234567890
# WEBHOOK_SECRET: any random string you generate (e.g. openssl rand -hex 32)
#               used to verify that webhook calls come from Telegram, not a third party
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DISCUSSION_GROUP_ID=
TELEGRAM_CONTENT_CHANNEL_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# Stripe
# SECRET_KEY:      Stripe Dashboard → Developers → API keys → Secret key (sk_test_...)
# WEBHOOK_SECRET:  Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret (whsec_...)
#                  Local dev: use Stripe CLI → stripe listen → it gives you a temporary whsec_
# PRICE_ID:        Stripe Dashboard → Products → your product → price ID (price_...)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STANDARD_STRIPE_PRICE_ID=price_
VIP_STRIPE_PRICE_ID=price_
STANDARD_PRICE_DISPLAY=29 €/mėn.
VIP_PRICE_DISPLAY=49 €/mėn.

# ─────────────────────────────────────────
# AI — Claude (optional, v2 only)
# ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-
