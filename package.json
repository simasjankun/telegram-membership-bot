    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@prisma/client": "^6.19.2",
    "joi": "^17.13.0",
    "nestjs-telegraf": "^2.9.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "prisma": "^6.19.2",
    "typescript": "^5.4.0"
